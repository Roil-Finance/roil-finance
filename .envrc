# Canton Rebalancer - Environment setup
# Source this file: source .envrc

if [ -z "$JAVA_HOME" ]; then
  if [ -d "/c/jdk-17.0.2" ]; then
    export JAVA_HOME="/c/jdk-17.0.2"
  elif command -v java &>/dev/null; then
    export JAVA_HOME="$(dirname $(dirname $(readlink -f $(which java))))"
  fi
fi
export PATH="$HOME/AppData/Roaming/daml/sdk/3.4.11/daml:$JAVA_HOME/bin:$PATH"

# Fix Turkish locale issue (Java converts 'i' to 'İ' in Turkish, breaking Daml)
export JAVA_TOOL_OPTIONS="-Duser.language=en -Duser.country=US"

# Docker
export PATH="/c/Program Files/Docker/Docker/resources/bin:/c/Program Files/Docker/Docker:$PATH"
