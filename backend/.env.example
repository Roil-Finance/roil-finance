# Canton Rebalancer Backend Configuration
# Copy to .env and fill in values

# --- Network ---
# localnet | devnet | testnet | mainnet
CANTON_NETWORK=localnet

# --- Server ---
PORT=3001

# --- Canton Ledger API ---
# cn-quickstart defaults: SV=4975, AppProvider=3975, AppUser=2975
JSON_API_URL=http://localhost:3975
GRPC_API_URL=http://localhost:3901
SCAN_URL=http://scan.localhost:4000

# --- Party IDs ---
PLATFORM_PARTY=app-provider::1220placeholder
LEDGER_USER_ID=app-provider
APPLICATION_ID=canton-rebalancer

# --- JWT Auth ---
# unsafe | hmac256 | rs256 | es256
JWT_MODE=unsafe
JWT_SECRET=canton-rebalancer-dev-secret
JWT_PRIVATE_KEY_PATH=
JWT_AUDIENCE=https://daml.com/jwt/aud/participant/sandbox

# --- Cantex DEX ---
# Leave empty for mock mode (localnet)
CANTEX_API_URL=
CANTEX_OPERATOR_KEY=
CANTEX_TRADING_KEY=

# --- Asset Admin Parties ---
CC_ADMIN_PARTY=
USDCX_ADMIN_PARTY=
CBTC_ADMIN_PARTY=

# --- Daml Package ---
DAML_PACKAGE_NAME=canton-rebalancer

# --- Cron ---
DCA_CRON=0 * * * *
REBALANCE_CRON=*/15 * * * *
