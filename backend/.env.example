# =============================================================================
# Roil Backend Configuration
# =============================================================================
# Copy to `.env` and fill in values. Values differ per network.
# For MainNet cutover see `docs/runbook.md` §8.
# =============================================================================

# --- Network -----------------------------------------------------------------
# localnet | devnet | testnet | mainnet
CANTON_NETWORK=localnet

# --- Server ------------------------------------------------------------------
PORT=3001
# Comma-separated list of origins allowed by CORS (required outside localnet).
# Example production value: "https://roil.app,https://www.roil.app,https://api.roil.app"
ALLOWED_ORIGINS=

# --- Canton Ledger API -------------------------------------------------------
# localnet defaults: SV=4975, AppProvider=3975, AppUser=2975
# TestNet (Caddy fronting Splice nginx): http://localhost/ (via host-rewrite)
# MainNet: set to the JSON Ledger API URL of the local validator participant
JSON_API_URL=http://localhost:3975
GRPC_API_URL=http://localhost:3901
SCAN_URL=http://scan.localhost:4000

# --- Party IDs ---------------------------------------------------------------
# Platform party is the Roil operator (JWT must be able to actAs this party).
PLATFORM_PARTY=app-provider::1220placeholder
LEDGER_USER_ID=app-provider
APPLICATION_ID=roil-finance

# Validator party (optional; used for FA reward beneficiary split when dual-role)
VALIDATOR_PARTY=

# --- JWT Auth ----------------------------------------------------------------
# Mode: unsafe (localnet only) | hmac256 | rs256 | es256
JWT_MODE=unsafe
# HMAC secret (hmac256 mode)
JWT_SECRET=roil-finance-dev-secret
# Private-key path for rs256/es256 (PEM). Required if JWT_MODE=rs256 or es256.
JWT_PRIVATE_KEY_PATH=
# Public-key path used to verify incoming JWTs (rs256/es256).
JWT_PUBLIC_KEY_PATH=
# Audience claim Canton validates (must match participant config).
# localnet/dev default: https://daml.com/jwt/aud/participant/sandbox
# TestNet/MainNet: typically the participant's URL or a DA-supplied value.
JWT_AUDIENCE=https://daml.com/jwt/aud/participant/sandbox

# --- Daml Package ------------------------------------------------------------
DAML_PACKAGE_NAME=roil-finance

# --- Asset Admin Parties (all required outside localnet) ---------------------
# CC is the DSO party on the target network. Fetch via:
#   TOKEN=$(python3 /root/splice-node/docker-compose/validator/get-token.py administrator)
#   curl -H "Authorization: Bearer $TOKEN" \
#     http://localhost/api/validator/v0/scan-proxy/dso-party-id \
#     -H 'Host: wallet.localhost'
CC_ADMIN_PARTY=
# USDCx is the Circle/DA xReserve operator. TestNet value is
# `decentralized-usdc-interchain-rep::12204...` — MainNet value must be
# confirmed with Circle/DA before launch.
USDCX_ADMIN_PARTY=
CBTC_ADMIN_PARTY=
ETHX_ADMIN_PARTY=
SOLX_ADMIN_PARTY=
XAUT_ADMIN_PARTY=
XAGT_ADMIN_PARTY=
USTB_ADMIN_PARTY=
MMF_ADMIN_PARTY=

# --- Featured App (CIP-0047) -------------------------------------------------
# Set this after GSF registration completes; leave blank to fall back to local
# marker-only mode (no CC reward accrual).
FEATURED_APP_RIGHT_CID=
# Split between platform and validator beneficiary (0.0–1.0 fraction that goes
# to the platform).
APP_REWARD_SPLIT_PCT=1.0

# --- Cantex DEX --------------------------------------------------------------
# Leave empty for mock mode (localnet only).
# On TestNet/MainNet these must be set or the DEX integration silently becomes
# a simulator — operator must grep the startup log for "MOCK mode" warning.
CANTEX_API_URL=
CANTEX_OPERATOR_KEY=
CANTEX_TRADING_KEY=

# --- Temple DEX --------------------------------------------------------------
TEMPLE_API_URL=
TEMPLE_API_KEY=

# --- xReserve / USDC bridge --------------------------------------------------
# Ethereum RPC (Sepolia for TestNet, mainnet for production).
ETH_RPC_URL=
XRESERVE_CHAIN=testnet

# --- Traffic subsidy (App Reward economics) ----------------------------------
# When true, backend pays synchronizer traffic fees on behalf of users.
SUBSIDIZE_TRAFFIC=false
# Auto-top-up config for the validator's traffic balance.
TRAFFIC_TARGET_THROUGHPUT=20000
TRAFFIC_MIN_TOPUP_INTERVAL=60

# --- Rate limits -------------------------------------------------------------
RATE_LIMIT_MAX=100
RATE_LIMIT_MAX_KEYS=50000
REDIS_URL=

# --- Engine tuning -----------------------------------------------------------
SLIPPAGE_TOLERANCE=0.02
PLATFORM_FEE_RATE=0.001
# Fallback CC→USDCx price used when oracle is unavailable. MUST be set outside
# localnet, otherwise USD-denominated math throws at first use.
CC_FALLBACK_PRICE=

# --- Cron schedules ----------------------------------------------------------
DCA_CRON=0 * * * *
REBALANCE_CRON=*/15 * * * *

# --- Monitoring / observability ---------------------------------------------
# OpenTelemetry OTLP endpoint for traces (leave empty to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=roil-backend

# --- Postgres (optional, backend state — not the validator DB) --------------
# Leave empty for in-memory fallback (not recommended for production).
DATABASE_URL=
