  pure ()

-- | Test 19: ViewWhitelistStats — verify nonconsuming choice
testViewWhitelistStats : Script ()
testViewWhitelistStats = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"

  let t0 = time (date 2026 Mar 15) 10 0 0

  configCid <- submit platform do
    createCmd (mkDefaultWhitelist platform)

  -- View stats initially
  (total, maxU, isOpen) <- submit platform do
    exerciseCmd configCid ViewWhitelistStats
  assertMsg "Initial total should be 0" (total == 0)
  assertMsg "Max should be 1000" (maxU == 1000)
  assertMsg "Should be open" isOpen

  -- Add Alice
  (configCid, _) <- submit platform do
    exerciseCmd configCid AddToWhitelist with
      user = alice
      email = None
      invitedBy = None
      joinedAt = t0

  -- View stats after adding Alice
  (total, maxU, isOpen) <- submit platform do
    exerciseCmd configCid ViewWhitelistStats
  assertMsg "Total should be 1" (total == 1)

  -- Add Bob
  (configCid, _) <- submit platform do
    exerciseCmd configCid AddToWhitelist with
      user = bob
      email = None
      invitedBy = Some alice
      joinedAt = t0

  -- View stats after adding Bob
  (total, _, _) <- submit platform do
    exerciseCmd configCid ViewWhitelistStats
  assertMsg "Total should be 2" (total == 2)

  pure ()

-- | Test 20: Pause already-paused treasury should fail, resume non-paused should fail
testPauseResumeEdgeCases : Script ()
testPauseResumeEdgeCases = script do
  platform <- allocateParty "Platform"
  tokenAdmin <- allocateParty "TokenAdmin"

  let t0 = time (date 2026 Mar 15) 10 0 0

  poolCid <- submit platform do
    createCmd (mkDefaultPool platform tokenAdmin t0)

  -- Resume non-paused should fail
  submitMustFail platform do
    exerciseCmd poolCid ResumeTreasury

  -- Pause
  poolCid <- submit platform do
    exerciseCmd poolCid PauseTreasury

  -- Pause again should fail
  submitMustFail platform do
    exerciseCmd poolCid PauseTreasury

  pure ()
