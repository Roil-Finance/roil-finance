-- | Test 17: Update spread rate — verify new rate persists
testUpdateSpreadRate : Script ()
testUpdateSpreadRate = script do
  platform <- allocateParty "Platform"
  tokenAdmin <- allocateParty "TokenAdmin"

  let t0 = time (date 2026 Mar 15) 10 0 0
  let t1 = time (date 2026 Mar 15) 10 5 0

  poolCid <- submit platform do
    createCmd (mkDefaultPool platform tokenAdmin t0)

  -- Update spread rate to 1%
  poolCid <- submit platform do
    exerciseCmd poolCid UpdateSpreadRate with
      newSpreadRate = 0.01
      updatedAt = t1

  pools <- query @TreasuryPool platform
  let (_, pool) = head pools
  assertMsg "Spread rate should be 0.01" (pool.spreadRate == 0.01)

  -- Invalid spread (0.0) should fail
  submitMustFail platform do
    exerciseCmd poolCid UpdateSpreadRate with
      newSpreadRate = 0.0
      updatedAt = t1

  -- Invalid spread (0.1 = 10%) should fail
  submitMustFail platform do
    exerciseCmd poolCid UpdateSpreadRate with
      newSpreadRate = 0.1
      updatedAt = t1

  pure ()

-- | Test 18: Inactive member cannot use invite codes
testInactiveMemberInviteCode : Script ()
testInactiveMemberInviteCode = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"

  let t0 = time (date 2026 Mar 15) 10 0 0

  configCid <- submit platform do
    createCmd (mkDefaultWhitelist platform)

  (configCid, memberCid) <- submit platform do
    exerciseCmd configCid AddToWhitelist with
      user = alice
      email = None
      invitedBy = None
      joinedAt = t0

  -- Deactivate
  memberCid <- submit platform do
    exerciseCmd memberCid DeactivateMember

  -- Try to use invite code while inactive — should fail
  submitMustFail platform do
