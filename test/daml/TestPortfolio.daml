-- | Tests for Portfolio and Rebalance contracts
module TestPortfolio where

import Daml.Script
import DA.List (head)
import DA.Date
import DA.Time
import DA.TextMap (empty)
import Types
import Portfolio
import DCA
import RewardTracker
import qualified FeaturedApp

-- | Helper: create test asset IDs
mkAssetId : Party -> Text -> AssetId
mkAssetId admin symbol = AssetId with symbol; admin

-- | Helper: record N transactions (top-level to avoid local recursion)
recordTxs : Party -> ContractId RewardTracker -> Int -> Script (ContractId RewardTracker)
recordTxs _ cid 0 = pure cid
recordTxs platform cid n = do
  newCid <- submit platform do
    exerciseCmd cid RecordTx with
      txMinValue = 10.0
      txValue = 50.0
  recordTxs platform newCid (n - 1)

-- | Test: Full portfolio lifecycle
-- Create proposal -> accept -> set targets -> sync holdings -> check drift -> rebalance
testPortfolioLifecycle : Script ()
testPortfolioLifecycle = script do
  -- Setup parties
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  tokenAdmin <- allocateParty "TokenAdmin"

  let cc    = mkAssetId tokenAdmin "CC"
  let usdcx = mkAssetId tokenAdmin "USDCx"
  let cbtc  = mkAssetId tokenAdmin "CBTC"

  -- 1. Platform creates portfolio proposal for Alice
  proposalCid <- submit platform do
    createCmd PortfolioProposal with
      platform
      user = alice

  -- 2. Alice accepts with target allocations
  portfolioCid <- submit alice do
    exerciseCmd proposalCid AcceptProposal with
      targets =
        [ TargetAllocation cc    40.0
        , TargetAllocation usdcx 35.0
        , TargetAllocation cbtc  25.0
        ]
      triggerMode = DriftThreshold 5.0
      now = time (date 2026 Mar 15) 09 0 0

  -- 3. Platform syncs holdings (simulating on-chain balance query)
  portfolioCid <- submit platform do
    exerciseCmd portfolioCid SyncHoldings with
      newHoldings =
        [ Holding cc    1000.0 400.0
        , Holding usdcx 250.0  250.0
        , Holding cbtc  0.5    250.0
        ]

  -- 4. Check drift
  drift <- submit platform do
    exerciseCmd portfolioCid CheckDrift

  debug ("Max drift: " <> show drift)

  -- 5. Create more extreme drift scenario
  portfolioCid <- submit platform do
    exerciseCmd portfolioCid SyncHoldings with
      newHoldings =
        [ Holding cc    2000.0 600.0    -- 60% vs target 40% = 20% drift
        , Holding usdcx 150.0  150.0    -- 15% vs target 35% = 20% drift
        , Holding cbtc  0.5    250.0    -- 25% vs target 25% = 0% drift
        ]

  -- 6. Initiate rebalance (drift > 5% threshold)
  result <- submit platform do
    exerciseCmd portfolioCid InitiateRebalance with
      requestedAt = time (date 2026 Mar 15) 09 55 0
  let portfolioCid = result.portfolioCid
  let rebalanceCid = result.requestCid

  -- 7. Platform sets swap legs
  rebalanceCid <- submit platform do
    exerciseCmd rebalanceCid SetSwapLegs with
      legs =
        [ SwapLeg cc usdcx 200.0 200.0
        ]

  -- 8. Complete rebalance
  completeResult <- submit platform do
    exerciseCmd rebalanceCid CompleteRebalance with
      executedLegs = [ SwapLeg cc usdcx 200.0 198.5 ]
      completedAt = time (date 2026 Mar 15) 10 0 0

  -- Verify log exists
  logs <- query @RebalanceLog alice
  assertMsg "Should have 1 rebalance log" (length logs == 1)

  pure ()

-- | Test: Target validation
testTargetValidation : Script ()
testTargetValidation = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  tokenAdmin <- allocateParty "TokenAdmin"

  let cc    = mkAssetId tokenAdmin "CC"
  let usdcx = mkAssetId tokenAdmin "USDCx"

  proposalCid <- submit platform do
    createCmd PortfolioProposal with
      platform
      user = alice

  -- Should fail: targets don't sum to 100%
  submitMustFail alice do
    exerciseCmd proposalCid AcceptProposal with
      targets =
        [ TargetAllocation cc    50.0
        , TargetAllocation usdcx 30.0
        ]
      triggerMode = Manual
      now = time (date 2026 Mar 15) 10 0 0

  pure ()

-- | Test: Target must have at least 2 assets
testMinAssets : Script ()
testMinAssets = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  tokenAdmin <- allocateParty "TokenAdmin"

  let cc = mkAssetId tokenAdmin "CC"

  proposalCid <- submit platform do
    createCmd PortfolioProposal with
      platform
      user = alice

  -- Should fail: only 1 asset
  submitMustFail alice do
    exerciseCmd proposalCid AcceptProposal with
      targets = [ TargetAllocation cc 100.0 ]
      triggerMode = Manual
      now = time (date 2026 Mar 15) 10 0 0

  pure ()

-- | Test: Update targets
testUpdateTargets : Script ()
testUpdateTargets = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  tokenAdmin <- allocateParty "TokenAdmin"

  let cc    = mkAssetId tokenAdmin "CC"
  let usdcx = mkAssetId tokenAdmin "USDCx"
  let cbtc  = mkAssetId tokenAdmin "CBTC"

  proposalCid <- submit platform do
    createCmd PortfolioProposal with platform; user = alice

  portfolioCid <- submit alice do
    exerciseCmd proposalCid AcceptProposal with
      targets =
        [ TargetAllocation cc    50.0
        , TargetAllocation usdcx 50.0
        ]
      triggerMode = Manual
      now = time (date 2026 Mar 15) 10 0 0

  -- Update to 3-asset portfolio
  portfolioCid <- submit alice do
    exerciseCmd portfolioCid UpdateTargets with
      newTargets =
        [ TargetAllocation cc    40.0
        , TargetAllocation usdcx 35.0
        , TargetAllocation cbtc  25.0
        ]

  portfolios <- query @Portfolio alice
  assertMsg "Should have 1 portfolio" (length portfolios == 1)

  pure ()

-- | Test: DCA full lifecycle
testDCALifecycle : Script ()
testDCALifecycle = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  tokenAdmin <- allocateParty "TokenAdmin"

  let usdcx = mkAssetId tokenAdmin "USDCx"
  let cbtc  = mkAssetId tokenAdmin "CBTC"

  -- Create DCA schedule: buy CBTC with 100 USDCx weekly
  scheduleCid <- submit platform do
    createCmd DCASchedule with
      platform
      user = alice
      sourceAsset = usdcx
      targetAsset = cbtc
      amountPerBuy = 100.0
      frequency = Weekly
      totalExecutions = 0
      isActive = True
      createdAt = time (date 2026 Mar 15) 10 0 0

  -- Execute DCA
  execResult <- submit platform do
    exerciseCmd scheduleCid ExecuteDCA with
      executedAt = time (date 2026 Mar 15) 10 0 0
  let scheduleCid = execResult.scheduleCid
  let execCid = execResult.executionCid

  -- Complete execution
  completeResult <- submit platform do
    exerciseCmd execCid CompleteDCAExecution with
      receivedAmount = 0.0025
      completedAt = time (date 2026 Mar 22) 10 0 0

  -- Execute again
  execResult2 <- submit platform do
    exerciseCmd scheduleCid ExecuteDCA with
      executedAt = time (date 2026 Mar 22) 10 0 0
  let scheduleCid = execResult2.scheduleCid
  let execCid = execResult2.executionCid

  completeResult2 <- submit platform do
    exerciseCmd execCid CompleteDCAExecution with
      receivedAmount = 0.0024
      completedAt = time (date 2026 Mar 29) 10 0 0

  -- Verify 2 execution logs
  logs <- query @DCALog alice
  assertMsg "Should have 2 DCA logs" (length logs == 2)

  -- Pause DCA
  scheduleCid <- submit alice do
    exerciseCmd scheduleCid PauseDCA

  -- Should fail: DCA is paused
  submitMustFail platform do
    exerciseCmd scheduleCid ExecuteDCA with
      executedAt = time (date 2026 Mar 29) 12 0 0

  pure ()

-- | Test: Reward tracking
testRewardTracking : Script ()
testRewardTracking = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"

  -- Create reward tracker for March
  trackerCid <- submit platform do
    createCmd RewardTracker with
      platform
      user = alice
      monthId = "2026-03"
      txCount = 0
      tier = Bronze
      previousTier = None
      consecutiveMonths = 0
      totalRewardsEarned = 0.0

  -- Record 55 transactions (should reach Silver)
  trackerCid <- recordTxs platform trackerCid 55

  -- Check stats
  (count, tier, _, _) <- submit alice do
    exerciseCmd trackerCid ViewStats

  assertMsg "Should have 55 TXs" (count == 55)
  assertMsg "Should be Silver tier" (tier == Silver)

  -- Distribute reward and roll over
  distResult <- submit platform do
    exerciseCmd trackerCid DistributeReward with
      rewardAmount = 10.0
      newMonthId = "2026-04"
      distributedAt = time (date 2026 Mar 31) 23 59 0

  -- Verify payout
  payouts <- query @RewardPayout alice
  assertMsg "Should have 1 payout" (length payouts == 1)

  pure ()

-- | Test: Featured App Rewards integration
testFeaturedApp : Script ()
testFeaturedApp = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"

  -- Create featured app config
  configCid <- submit platform do
    createCmd FeaturedApp.FeaturedAppConfig with
      platform
      appName = "Roil"
      isRegistered = False
      featuredAppRightCid = None
      totalActivities = 0
      lastActivityAt = None

  -- Record a rebalance activity
  (configCid, activityCid1) <- submit platform do
    exerciseCmd configCid FeaturedApp.RecordActivity with
      user = alice
      activityType = FeaturedApp.Rebalance
      activityId = "rebalance-001"
      description = "Portfolio rebalance executed"
      now = time (date 2026 Mar 15) 12 0 0

  -- Verify Alice can see the activity
  aliceActivities <- query @FeaturedApp.ActivityRecord alice
  assertMsg "Alice should have 1 activity" (length aliceActivities == 1)

  -- Record a DCA execution activity
  (configCid, activityCid2) <- submit platform do
    exerciseCmd configCid FeaturedApp.RecordActivity with
      user = alice
      activityType = FeaturedApp.DCAExecution
      activityId = "dca-001"
      description = "DCA #1: 100 USDCx -> CBTC"
      now = time (date 2026 Mar 15) 13 0 0

  -- Record activity for a different user
  (configCid, activityCid3) <- submit platform do
    exerciseCmd configCid FeaturedApp.RecordActivity with
      user = bob
      activityType = FeaturedApp.CompoundExecution
      activityId = "compound-001"
      description = "Compound yield reinvested"
      now = time (date 2026 Mar 15) 14 0 0

  -- Verify activity counts
  aliceActivities <- query @FeaturedApp.ActivityRecord alice
  assertMsg "Alice should have 2 activities" (length aliceActivities == 2)

  bobActivities <- query @FeaturedApp.ActivityRecord bob
  assertMsg "Bob should have 1 activity" (length bobActivities == 1)

  -- Update registration status (simulating GSF registration)
  configCid <- submit platform do
    exerciseCmd configCid FeaturedApp.UpdateRegistration with
      newIsRegistered = True
      newFeaturedAppRightCid = Some "00abc123deadbeef"

  -- Record reward distribution activity after registration
  (configCid, activityCid4) <- submit platform do
    exerciseCmd configCid FeaturedApp.RecordActivity with
      user = alice
      activityType = FeaturedApp.RewardDistribution
      activityId = "reward-001"
      description = "Monthly rewards distributed: 10.0 CC"
      now = time (date 2026 Apr 1) 0 5 0

  -- Verify total activities (4 recorded)
  allActivities <- query @FeaturedApp.ActivityRecord platform
  assertMsg "Platform should see 4 activities" (length allActivities == 4)

  pure ()

-- | Test: Deactivate → rebalance fails → Reactivate → rebalance succeeds
testDeactivateReactivate : Script ()
testDeactivateReactivate = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  tokenAdmin <- allocateParty "TokenAdmin"

  let cc    = mkAssetId tokenAdmin "CC"
  let usdcx = mkAssetId tokenAdmin "USDCx"

  -- Create portfolio (proposal → accept)
  proposalCid <- submit platform do
    createCmd PortfolioProposal with
      platform
      user = alice

  portfolioCid <- submit alice do
    exerciseCmd proposalCid AcceptProposal with
      targets =
        [ TargetAllocation cc    50.0
        , TargetAllocation usdcx 50.0
        ]
      triggerMode = Manual
      now = time (date 2026 Mar 15) 09 0 0

  -- Sync holdings with drift to allow rebalance
  portfolioCid <- submit platform do
    exerciseCmd portfolioCid SyncHoldings with
      newHoldings =
        [ Holding cc    2000.0 800.0    -- 80% vs target 50%
        , Holding usdcx 200.0  200.0    -- 20% vs target 50%
        ]

  -- Deactivate the portfolio
  portfolioCid <- submit alice do
    exerciseCmd portfolioCid DeactivatePortfolio

  -- Try to InitiateRebalance → should fail (isActive check)
  submitMustFail platform do
    exerciseCmd portfolioCid InitiateRebalance with
      requestedAt = time (date 2026 Mar 15) 10 0 0

  -- Reactivate the portfolio
  portfolioCid <- submit alice do
    exerciseCmd portfolioCid ActivatePortfolio

  -- InitiateRebalance → should succeed
  result <- submit platform do
    exerciseCmd portfolioCid InitiateRebalance with
      requestedAt = time (date 2026 Mar 15) 10 5 0

  pure ()

-- | Test: Fail a rebalance request
testFailRebalance : Script ()
testFailRebalance = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  tokenAdmin <- allocateParty "TokenAdmin"

  let cc    = mkAssetId tokenAdmin "CC"
  let usdcx = mkAssetId tokenAdmin "USDCx"

  -- Create portfolio
  proposalCid <- submit platform do
    createCmd PortfolioProposal with
      platform
      user = alice

  portfolioCid <- submit alice do
    exerciseCmd proposalCid AcceptProposal with
      targets =
        [ TargetAllocation cc    60.0
        , TargetAllocation usdcx 40.0
        ]
      triggerMode = Manual
      now = time (date 2026 Mar 15) 10 0 0

  -- Sync holdings with drift
  portfolioCid <- submit platform do
    exerciseCmd portfolioCid SyncHoldings with
      newHoldings =
        [ Holding cc    3000.0 900.0    -- 90% vs target 60%
        , Holding usdcx 100.0  100.0    -- 10% vs target 40%
        ]

  -- Initiate rebalance
  result <- submit platform do
    exerciseCmd portfolioCid InitiateRebalance with
      requestedAt = time (date 2026 Mar 15) 11 0 0
  let portfolioCid = result.portfolioCid
  let rebalanceCid = result.requestCid

  -- Fail the rebalance with a reason
  failedCid <- submit platform do
    exerciseCmd rebalanceCid FailRebalance with
      reason = "Cantex swap execution error"

  -- Verify the request still exists (FailRebalance creates a new contract with Failed status)
  requests <- query @RebalanceRequest alice
  assertMsg "Should have 1 rebalance request" (length requests == 1)

  pure ()

-- | Test: Below threshold rebalance should fail
testBelowThresholdRebalance : Script ()
testBelowThresholdRebalance = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  tokenAdmin <- allocateParty "TokenAdmin"

  let cc    = mkAssetId tokenAdmin "CC"
  let usdcx = mkAssetId tokenAdmin "USDCx"

  -- Create portfolio with DriftThreshold 10.0
  proposalCid <- submit platform do
    createCmd PortfolioProposal with
      platform
      user = alice

  portfolioCid <- submit alice do
    exerciseCmd proposalCid AcceptProposal with
      targets =
        [ TargetAllocation cc    50.0
        , TargetAllocation usdcx 50.0
        ]
      triggerMode = DriftThreshold 10.0
      now = time (date 2026 Mar 15) 10 0 0

  -- Sync holdings that create only 2% drift (below threshold of 10%)
  portfolioCid <- submit platform do
    exerciseCmd portfolioCid SyncHoldings with
      newHoldings =
        [ Holding cc    1000.0 510.0    -- 51% vs target 50% = 1% drift
        , Holding usdcx 490.0  490.0    -- 49% vs target 50% = 1% drift
        ]

  -- Try InitiateRebalance → should fail (drift below threshold)
  submitMustFail platform do
    exerciseCmd portfolioCid InitiateRebalance with
      requestedAt = time (date 2026 Mar 15) 12 0 0

  pure ()

-- | Test: DCA cancel archives the contract
testDCACancel : Script ()
testDCACancel = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  tokenAdmin <- allocateParty "TokenAdmin"

  let usdcx = mkAssetId tokenAdmin "USDCx"
  let cbtc  = mkAssetId tokenAdmin "CBTC"

  -- Create DCA schedule
  scheduleCid <- submit platform do
    createCmd DCASchedule with
      platform
      user = alice
      sourceAsset = usdcx
      targetAsset = cbtc
      amountPerBuy = 100.0
      frequency = Weekly
      totalExecutions = 0
      isActive = True
      createdAt = time (date 2026 Mar 15) 10 0 0

  -- Cancel DCA
  submit alice do
    exerciseCmd scheduleCid CancelDCA

  -- Verify it's archived (can't exercise on it anymore)
  submitMustFail platform do
    exerciseCmd scheduleCid ExecuteDCA with
      executedAt = time (date 2026 Mar 15) 12 0 0

  pure ()

-- | Test: DCA update amount
testDCAUpdateAmount : Script ()
testDCAUpdateAmount = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  tokenAdmin <- allocateParty "TokenAdmin"

  let usdcx = mkAssetId tokenAdmin "USDCx"
  let cbtc  = mkAssetId tokenAdmin "CBTC"

  -- Create DCA schedule with amountPerBuy = 100.0
  scheduleCid <- submit platform do
    createCmd DCASchedule with
      platform
      user = alice
      sourceAsset = usdcx
      targetAsset = cbtc
      amountPerBuy = 100.0
      frequency = Weekly
      totalExecutions = 0
      isActive = True
      createdAt = time (date 2026 Mar 15) 10 0 0

  -- Update amount to 200.0
  scheduleCid <- submit alice do
    exerciseCmd scheduleCid UpdateDCAAmount with
      newAmount = 200.0

  -- Verify new amount by querying
  schedules <- query @DCASchedule alice
  assertMsg "Should have 1 DCA schedule" (length schedules == 1)
  let (_, schedule) = head schedules
  assertMsg "Amount should be 200.0" (schedule.amountPerBuy == 200.0)

  pure ()

-- | Test: Referral system
testReferralSystem : Script ()
testReferralSystem = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"

  -- Create Referral between alice (referrer) and bob (referee)
  referralCid <- submit platform do
    createCmd Referral with
      platform
      referrer = alice
      referee = bob
      isActive = True
      referrerBonusPct = 10.0
      createdAt = time (date 2026 Mar 15) 10 0 0

  -- Exercise CreditReferrer → creates ReferralCredit
  creditCid <- submit platform do
    exerciseCmd referralCid CreditReferrer with
      refereeTxValue = 500.0
      creditedAt = time (date 2026 Mar 15) 12 0 0

  -- Verify referral is still active (nonconsuming choice)
  referrals <- query @Referral alice
  assertMsg "Referral should still exist" (length referrals == 1)

  -- Verify credit was created with correct amount (10% of 500 = 50)
  credits <- query @ReferralCredit alice
  assertMsg "Should have 1 referral credit" (length credits == 1)
  let (_, credit) = head credits
  assertMsg "Credit amount should be 50.0" (credit.amount == 50.0)

  -- Exercise again to verify nonconsuming behavior
  creditCid2 <- submit platform do
    exerciseCmd referralCid CreditReferrer with
      refereeTxValue = 200.0
      creditedAt = time (date 2026 Mar 15) 13 0 0

  credits <- query @ReferralCredit alice
  assertMsg "Should have 2 referral credits" (length credits == 2)

  pure ()

-- | Test: Negative target percentage rejection
testNegativeTargetRejection : Script ()
testNegativeTargetRejection = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  tokenAdmin <- allocateParty "TokenAdmin"

  let cc    = mkAssetId tokenAdmin "CC"
  let usdcx = mkAssetId tokenAdmin "USDCx"

  proposalCid <- submit platform do
    createCmd PortfolioProposal with
      platform
      user = alice

  -- Try to create portfolio with negative targetPct → should fail
  submitMustFail alice do
    exerciseCmd proposalCid AcceptProposal with
      targets =
        [ TargetAllocation cc    (-10.0)
        , TargetAllocation usdcx 110.0
        ]
      triggerMode = Manual
      now = time (date 2026 Mar 15) 10 0 0

  pure ()

-- | Test: Compound config lifecycle
testCompoundConfig : Script ()
testCompoundConfig = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"

  -- Create compound config
  configCid <- submit platform do
    createCmd CompoundConfig with
      platform
      user = alice
      strategy = "portfolio-targets"
      minYieldThreshold = 10.0
      isEnabled = True
      lastCompoundAt = None
      totalCompounded = 0.0

  -- User updates config
  configCid <- submit alice do
    exerciseCmd configCid UpdateCompoundConfig with
      newStrategy = "same-asset"
      newThreshold = 5.0
      newEnabled = True

  -- Platform records compound
  configCid <- submit platform do
    exerciseCmd configCid RecordCompound with
      compoundedAmount = 25.0
      compoundedAt = time (date 2026 Mar 17) 12 0 0

  -- Verify state
  configs <- query @CompoundConfig alice
  assertMsg "Should have 1 config" (length configs == 1)
  let (_, cfg) = head configs
  assertMsg "Strategy should be same-asset" (cfg.strategy == "same-asset")
  assertMsg "Total compounded should be 25.0" (cfg.totalCompounded == 25.0)

  pure ()

-- | Test: User preferences
testUserPreferences : Script ()
testUserPreferences = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"

  -- Create preferences
  prefsCid <- submit platform do
    createCmd UserPreferences with
      platform
      user = alice
      defaultDriftPct = 5.0
      slippageTolerance = 0.02
      notificationsOn = True
      autoRebalanceOn = True
      createdAt = time (date 2026 Mar 17) 0 0 0

  -- User updates preferences
  prefsCid <- submit alice do
    exerciseCmd prefsCid UpdatePreferences with
      newDriftPct = 3.0
      newSlippage = 0.05
      newNotifications = False
      newAutoRebalance = True

  -- Verify
  prefs <- query @UserPreferences alice
  assertMsg "Should have 1 prefs" (length prefs == 1)
  let (_, p) = head prefs
  assertMsg "Drift should be 3.0" (p.defaultDriftPct == 3.0)
  assertMsg "Notifications should be off" (not p.notificationsOn)

  pure ()

-- | Test: Duplicate asset rejection
testDuplicateAssetRejection : Script ()
testDuplicateAssetRejection = script do
  platform <- allocateParty "Platform"
  alice <- allocateParty "Alice"
  tokenAdmin <- allocateParty "TokenAdmin"

  let cc = mkAssetId tokenAdmin "CC"

  proposalCid <- submit platform do
    createCmd PortfolioProposal with
      platform
      user = alice

  -- Try to create portfolio with duplicate assets → should fail
  submitMustFail alice do
    exerciseCmd proposalCid AcceptProposal with
      targets =
        [ TargetAllocation cc 50.0
        , TargetAllocation cc 50.0
        ]
      triggerMode = Manual
      now = time (date 2026 Mar 15) 10 0 0

  pure ()
