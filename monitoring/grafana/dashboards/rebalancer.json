{
  "dashboard": {
    "id": null,
    "uid": "roil-finance",
    "title": "Roil",
    "tags": ["canton", "defi", "rebalancer"],
    "timezone": "browser",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "HTTP Requests / sec",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "rate(http_requests_total[1m])",
            "legendFormat": "{{method}} {{path}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "HTTP Latency p95 (ms)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_ms_bucket[5m]))",
            "legendFormat": "p95"
          }
        ]
      },
      {
        "id": 3,
        "title": "Active Portfolios",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
        "targets": [
          { "expr": "active_portfolios", "legendFormat": "Portfolios" }
        ]
      },
      {
        "id": 4,
        "title": "Active DCA Schedules",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
        "targets": [
          { "expr": "active_dca_schedules", "legendFormat": "DCA Schedules" }
        ]
      },
      {
        "id": 5,
        "title": "Circuit Breaker State",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
        "targets": [
          { "expr": "circuit_breaker_state", "legendFormat": "{{name}}" }
        ]
      },
      {
        "id": 6,
        "title": "Rebalances Executed",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
        "targets": [
          { "expr": "increase(rebalance_executed_total[24h])", "legendFormat": "24h" }
        ]
      },
      {
        "id": 7,
        "title": "DCA Executions",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          { "expr": "increase(dca_executed[1h])", "legendFormat": "per hour" }
        ]
      },
      {
        "id": 8,
        "title": "Rewards Distributed",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          { "expr": "increase(reward_distributed[24h])", "legendFormat": "per day" }
        ]
      }
    ]
  }
}
